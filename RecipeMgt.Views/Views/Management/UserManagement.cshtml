@using RecipeMgt.Application.Constant
@using RecipeMgt.Domain.Enums
@model RecipeMgt.Views.Models.ViewModels.UsersViewModel
@{
    ViewData["Title"] = "Người dùng";
    ViewData["ActiveNav"] = "users";
    ViewData["BreadcrumbParent"] = "Quản lý";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var status = Model.StatusFilter?.ToString();
    var pageSize = Model.PageSize.ToString();

}

<div class="page-header">
    <div>
        <h1 class="page-title">Quản lý Người dùng</h1>
        <p class="page-subtitle">Xem và quản lý tất cả tài khoản trong hệ thống</p>
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <input type="file" id="csvFile" accept=".csv" hidden />

        <button class="btn-outline-sm" onclick="document.getElementById('csvFile').click()">
            <i class="bi bi-upload"></i> Import CSV
        </button>
        <a href="#" class="btn-outline-sm" onclick="exportUsers()">
            <i class="bi bi-download"></i> Xuất CSV
        </a>
        
        <button class="btn-primary-sm" onclick="openCreateModal()">
            <i class="bi bi-plus-lg"></i> Thêm người dùng
        </button>

    </div>
</div>

@* ── Stat cards ── *@
<div class="stat-grid">
    <div class="stat-card">
        <div class="stat-icon blue"><i class="bi bi-people-fill"></i></div>
        <div>
            <div class="stat-value">@(Model?.TotalCount ?? 0)</div>
            <div class="stat-label">Tổng người dùng</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green"><i class="bi bi-person-check-fill"></i></div>
        <div>
            <div class="stat-value" id="activeCount">@Model?.ActiveCount</div>
            <div class="stat-label">Đang hoạt động</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon amber"><i class="bi bi-person-exclamation"></i></div>
        <div>
            <div class="stat-value" id="pendingCount">@Model?.PendingCount</div>
            <div class="stat-label">Chờ xác minh</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon red"><i class="bi bi-person-slash"></i></div>
        <div>
            <div class="stat-value" id="bannedCount">@Model?.BannedCount</div>
            <div class="stat-label">Bị cấm</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon violet"><i class="bi bi-journal-richtext"></i></div>
        <div>
            <div class="stat-value" id="recipeCount">@Model?.RecipeCount</div>
            <div class="stat-label">Tổng công thức</div>
        </div>
    </div>
</div>

@* ── Toolbar ── *@
<form asp-controller="Management" asp-action="UserManagement" method="get" id="filterForm">
    <div class="table-toolbar">
        <div class="search-box">
            <i class="bi bi-search"></i>
            <input type="text" name="searchQuery" id="searchQuery"
                   value="@Model?.SearchQuery"
                   placeholder="Tìm tên, email…" autocomplete="off" />
        </div>
        <input type="hidden" name="page" value="1" />
        <select class="filter-select" name="status" id="statusFilter">
            <option value="" selected="@(status == null ? "selected" : null)">Tất cả</option>
            <option value="0" selected="@(status == "0" ? "selected" : null)">Hoạt động</option>
            <option value="1" selected="@(status == "1" ? "selected" : null)">Không hoạt động</option>
            <option value="2" selected="@(status == "2" ? "selected" : null)">Bị cấm</option>
            <option value="3" selected="@(status == "3" ? "selected" : null)">Đã xoá</option>
        </select>

        <select class="filter-select" name="pageSize" id="pageSizeFilter">
            <option value="10" selected="@(pageSize == "10" ? "selected" : null)">10 / trang</option>
            <option value="25" selected="@(pageSize == "25" ? "selected" : null)">25 / trang</option>
            <option value="50" selected="@(pageSize == "50" ? "selected" : null)">50 / trang</option>
        </select>

        <div class="ms-auto" style="display:flex;gap:8px;">
            <button type="submit" class="btn-primary-sm">
                <i class="bi bi-funnel"></i> Lọc
            </button>
            <a asp-controller="Management" asp-action="UserManagement" class="btn-outline-sm">
                <i class="bi bi-arrow-counterclockwise"></i> Đặt lại
            </a>
        </div>
    </div>
</form>

<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width:520px;">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-person-plus me-2 text-indigo-500"></i>Thêm người dùng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="modal-alert error" id="createAlert"></div>
                <div class="form-row">
                    <div class="form-group" style="grid-column:1/-1;">
                        <label class="form-label">Họ tên <span class="req">*</span></label>
                        <input type="text" class="form-control" id="c_fullname" placeholder="Nguyễn Văn A" maxlength="100" />
                        <div class="invalid-feedback">Họ tên không được để trống</div>
                    </div>
                    <div class="form-group" style="grid-column:1/-1;">
                        <label class="form-label">Email <span class="req">*</span></label>
                        <input type="email" class="form-control" id="c_email" placeholder="example@email.com" maxlength="100" />
                        <div class="invalid-feedback">Email không hợp lệ</div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Mật khẩu <span class="req">*</span></label>
                        <div style="position:relative;">
                            <input type="password" class="form-control" id="c_password" placeholder="Tối thiểu 6 ký tự" style="padding-right:38px;" />
                            <button type="button" onclick="togglePwd('c_password',this)"
                                    style="position:absolute;right:10px;top:50%;transform:translateY(-50%);border:none;background:none;color:#94a3b8;cursor:pointer;">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <div class="invalid-feedback">Mật khẩu tối thiểu 6 ký tự</div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Vai trò</label>
                        <select class="form-control" id="c_role">
                            <option value="1">User</option>
                            <option value="2">Admin</option>
                        </select>
                    </div>
                    <div class="form-group" style="grid-column:1/-1;">
                        <label class="form-label">Trạng thái</label>
                        <div class="toggle-group">
                            <div class="form-check form-switch mb-0">
                                <input class="form-check-input" type="checkbox" id="c_actived" checked />
                            </div>
                            <span class="toggle-label">Kích hoạt tài khoản ngay</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-outline-sm" data-bs-dismiss="modal">Huỷ</button>
                <button type="button" class="btn-primary-sm" id="createSubmit" onclick="submitCreate()">
                    <span class="spinner-sm"></span>
                    <span class="btn-text"><i class="bi bi-plus-lg me-1"></i>Tạo tài khoản</span>
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width:520px;">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-pencil-square me-2"></i>Chỉnh sửa người dùng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="modal-alert error" id="editAlert"></div>
                <input type="hidden" id="e_userId" />
                <div class="form-row">
                    <div class="form-group" style="grid-column:1/-1;">
                        <label class="form-label">Họ tên</label>
                        <input type="text" class="form-control" id="e_fullname" maxlength="100" />
                    </div>
                    <div class="form-group" style="grid-column:1/-1;">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" id="e_email" maxlength="100" />
                    </div>
                    @* <div class="form-group">
                        <label class="form-label">Vai trò</label>
                        <select class="form-control" id="e_role">
                            <option value="1">User</option>
                            <option value="2">Admin</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Trạng thái</label>
                        <select class="form-control" id="e_status">
                            <option value="active_true_false">Hoạt động</option>
                            <option value="active_false_false">Không hoạt động</option>
                            <option value="active_false_true">Bị cấm</option>
                        </select>
                    </div> *@
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-outline-sm" data-bs-dismiss="modal">Huỷ</button>
                <button type="button" class="btn-primary-sm" id="editSubmit" onclick="submitEdit()">
                    <span class="spinner-sm"></span>
                    <span class="btn-text"><i class="bi bi-check-lg me-1"></i>Lưu thay đổi</span>
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width:400px;">
        <div class="modal-content">
            <div class="modal-header border-0">
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center pt-0">
                <div class="delete-icon-wrap"><i class="bi bi-trash3"></i></div>
                <h5 style="font-weight:700;color:#0f172a;margin-bottom:8px;">Xoá người dùng?</h5>
                <p style="color:#64748b;font-size:.85rem;margin:0;">
                    Bạn sắp xoá tài khoản <strong id="deleteUserName"></strong>.<br>
                    Hành động này <strong>không thể hoàn tác</strong>.
                </p>
                <input type="hidden" id="deleteUserId" />
            </div>
            <div class="modal-footer justify-content-center border-0 pt-0">
                <button type="button" class="btn-outline-sm" data-bs-dismiss="modal">Huỷ bỏ</button>
                <button type="button" id="deleteSubmit" onclick="submitDelete()"
                        style="display:inline-flex;align-items:center;gap:6px;padding:8px 20px;border-radius:9px;background:linear-gradient(135deg,#ef4444,#dc2626);color:#fff;font-size:.82rem;font-weight:600;border:none;cursor:pointer;">
                    <span class="spinner-sm"></span>
                    <span class="btn-text"><i class="bi bi-trash me-1"></i>Xoá ngay</span>
                </button>
            </div>
        </div>
    </div>
</div>

@* ── Table ── *@
<div class="table-wrapper">
    <div class="table-responsive">
        @if (Model?.Users != null && Model.Users.Any())
        {
            <table class="user-table" id="userTable">
                <thead>
                    <tr>
                        <th><input type="checkbox" class="form-check-input" id="checkAll" /></th>
                        <th>Người dùng</th>
                        <th class="hide-mobile">Vai trò</th>
                        <th class="hide-mobile">Trạng thái</th>
                        <th class="hide-mobile">Nền tảng</th>
                        <th class="hide-mobile">Công thức</th>
                        <th class="hide-mobile">Followers</th>
                        <th class="hide-mobile">Ngày tạo</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var colors = new[] { "c0","c1","c2","c3","c4" };
                        int idx = 0;
                    }
                    @foreach (var u in Model.Users)
                    {
                        var raw = u.FullName ?? "";
                        var parts = raw.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                        var initials = parts.Length > 0
                            ? string.Concat(parts.Select(w => w[0])).ToUpper()
                            : "?";
                        initials = initials.Length > 2 ? initials[..2] : initials;

                        var colorClass = colors[idx % colors.Length];
                        idx++;

                        var statusClass = u.UserStatus switch {
                            UserStatus.Active   => "badge-active",
                            UserStatus.Deactivated => "badge-inactive",
                            UserStatus.Banned   => "badge-banned",
                            UserStatus.Deleted  => "badge-deleted",
                            _                   => "badge-pending"
                        };
                        var statusLabel = u.UserStatus switch {
                            UserStatus.Active   => "Hoạt động",
                            UserStatus.Deactivated => "Không HĐ",
                            UserStatus.Banned   => "Bị cấm",
                            UserStatus.Deleted => "Da Xoa",
                            _                   => "Chờ xác minh"
                        };
                        var roleClass = u.RoleName?.ToLower() switch {
                            "admin" => "badge-role-admin",
                            "user"  => "badge-role-user",
                            _       => "badge-role-other"
                        };
                        var providerIcon = u.Provider?.ToLower() switch {
                            "google"   => "bi-google",
                            "facebook" => "bi-facebook",
                            "github"   => "bi-github",
                            _          => "bi-envelope"
                        };
                        var providerLabel = string.IsNullOrWhiteSpace(u.Provider) ? "Email" : u.Provider;

                        <tr>
                            <td>
                                <input type="checkbox" class="form-check-input row-check" value="@u.UserId" />
                            </td>
                            <td>
                                <div class="user-cell">
                                    <div class="user-ava @colorClass">@initials</div>
                                    <div>
                                        <div class="user-name">@(u.FullName ?? "(chưa đặt tên)")</div>
                                        <div class="user-email">@u.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td class="hide-mobile">
                                <span class="@roleClass">@(u.RoleName ?? "—")</span>
                            </td>
                            <td class="hide-mobile">
                                <span class="badge @statusClass">
                                    <span class="badge-dot"></span>
                                    @statusLabel
                                </span>
                            </td>
                            <td class="hide-mobile">
                                <span class="provider-badge">
                                    <i class="bi @providerIcon"></i>
                                    @providerLabel
                                </span>
                            </td>
                            <td class="hide-mobile">
                                <span class="mini-stat">
                                    <i class="bi bi-journal-text"></i>
                                    @u.TotalRecipes
                                </span>
                            </td>
                            <td class="hide-mobile">
                                <span class="mini-stat">
                                    <i class="bi bi-people"></i>
                                    @u.TotalFollowers
                                </span>
                            </td>
                            <td class="hide-mobile" style="color:#64748b;font-size:.78rem;">
                                @(u.CreatedAt.HasValue ? u.CreatedAt.Value.ToString("dd/MM/yyyy") : "—")
                            </td>
                            <td>
                                <div class="action-group">
                                    @* <a href="/admin/users/@u.UserId" class="act-btn" title="Xem chi tiết">
                                        <i class="bi bi-eye"></i>
                                    </a> *@
                                    <button class="act-btn" title="Chỉnh sửa"
                                            data-id="@u.UserId"
                                            data-name="@u.FullName"
                                            data-email="@u.Email"
                                            data-role="@(u.RoleName?.ToLower() == "admin" ? 2 : 1)"
                                            data-actived="@(u.UserStatus == UserStatus.Active ? "true" : "false")"
                                            data-banned="@(u.UserStatus == UserStatus.Banned ? "true" : "false")"
                                            onclick="openEditModal(this)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    @if (u.UserStatus == UserStatus.Banned)
                                    {
                                        <button class="act-btn success" title="Bỏ cấm"
                                                onclick="confirmUnban(@u.UserId, '@(u.FullName?.Replace("'","\\'")??"")' )">
                                            <i class="bi bi-person-check"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="act-btn danger" title="Cấm người dùng"
                                                onclick="confirmBan(@u.UserId, '@(u.FullName?.Replace("'","\\'")??"")' )">
                                            <i class="bi bi-person-slash"></i>
                                        </button>
                                    }
                                    <button class="act-btn danger" title="Xoá"
                                            data-id="@u.UserId"
                                            data-name="@u.FullName"
                                            onclick="confirmDelete(this)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @* ── Footer: info + pagination ── *@
            <div class="table-footer">
                <div class="page-info">
                    Hiển thị <strong>@((Model.Page - 1) * Model.PageSize + 1)</strong>
                    –
                    <strong>@Math.Min(Model.Page * Model.PageSize, Model.TotalCount)</strong>
                    trong <strong>@Model.TotalCount</strong> người dùng
                </div>

                @{
                    int totalPages = Model.PageCount;
                    var sq = !string.IsNullOrEmpty(Model.SearchQuery)
                    ? $"&searchQuery={Model.SearchQuery}" : "";

                    var sf = Model.StatusFilter.HasValue
                    ? $"&status={Model.StatusFilter}" : "";

                    var ps = $"&pageSize={Model.PageSize}";
                    
                string PageUrl(int p) => Url.Action("UserManagement", "Management", new {
                page = p,
                pageSize = Model.PageSize,
                searchQuery = Model.SearchQuery,
                status = Model.StatusFilter
                    })!;

                }
                <div class="pagination-group">
                    <a class="page-btn @(Model.Page <= 1 ? "disabled" : "")" href="@PageUrl(Model.Page - 1)">
                        <i class="bi bi-chevron-left"></i>
                    </a>

                    @{
                        int startP = Math.Max(1, Model.Page - 2);
                        int endP   = Math.Min(totalPages, Model.Page + 2);
                    }
                    @if (startP > 1)
                    {
                        <a class="page-btn" href="@PageUrl(1)">1</a>
                        @if (startP > 2) { <span class="page-btn disabled">…</span> }
                    }
                    @for (int p = startP; p <= endP; p++)
                    {
                        <a class="page-btn @(p == Model.Page ? "active" : "")" href="@PageUrl(p)">@p</a>
                    }
                    @if (endP < totalPages)
                    {
                        @if (endP < totalPages - 1) { <span class="page-btn disabled">…</span> }
                        <a class="page-btn" href="@PageUrl(totalPages)">@totalPages</a>
                    }

                    <a class="page-btn @(Model.Page >= totalPages ? "disabled" : "")" href="@PageUrl(Model.Page + 1)">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </div>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-people"></i>
                <strong style="color:#64748b;">Không có người dùng nào</strong>
                <p>Thử thay đổi bộ lọc hoặc từ khoá tìm kiếm.</p>
            </div>
        }
    </div>
</div>

@* ── Ban / Unban confirm modal ── *@
<div class="modal fade" id="banModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:16px;border:none;box-shadow:0 20px 60px rgba(0,0,0,.15);">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="banModalTitle">Xác nhận</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-2" id="banModalBody"></div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn-outline-sm" data-bs-dismiss="modal">Huỷ</button>
                <button type="button" class="btn-primary-sm" id="banSubmit"> Xác nhận</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/usermgt.js"></script>
}

