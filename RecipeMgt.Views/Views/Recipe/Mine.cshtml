@* ══════════ DELETE MODAL ══════════ *@
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width:400px;">
        <div class="modal-content">
            <div class="modal-header border-0">
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center pt-0">
                <div class="delete-icon-box"><i class="bi bi-trash3"></i></div>
                <h5 style="font-weight:700;color:var(--text);margin-bottom:8px;">Xoá công thức?</h5>
                <p style="color:var(--text-muted);font-size:.85rem;margin:0;">
                    Bạn sắp xoá <strong id="deleteTitle"></strong>.<br>
                    Hành động này <strong>không thể hoàn tác</strong>.
                </p>
                <input type="hidden" id="deleteId" />
            </div>
            <div class="modal-footer justify-content-center border-0 pt-0">
                <button type="button" class="btn-ghost" data-bs-dismiss="modal">Giữ lại</button>
                <button type="button" id="deleteSubmit" onclick="submitDelete()"
                        style="display:inline-flex;align-items:center;gap:6px;padding:9px 22px;border-radius:50px;background:linear-gradient(135deg,#ef4444,#dc2626);color:#fff;font-size:.85rem;font-weight:600;border:none;cursor:pointer;">
                    <span class="spinner-sm"></span>
                    <span class="btn-text"><i class="bi bi-trash me-1"></i>Xoá ngay</span>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const createModal = new bootstrap.Modal(document.getElementById('createModal'));
            const editModal   = new bootstrap.Modal(document.getElementById('editModal'));
            const deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));

            /* ── helpers ── */
            function setLoading(btnId, on) {
                const btn = document.getElementById(btnId);
                if (!btn) return;
                btn.classList.toggle('btn-loading', on);
                btn.disabled = on;
            }
            function showAlert(id, msg) {
                const el = document.getElementById(id);
                el.textContent = msg;
                el.className = 'm-alert error show';
            }
            function hideAlert(id) {
                document.getElementById(id).className = 'm-alert error';
            }
            function resetInvalid(...ids) {
                ids.forEach(id => document.getElementById(id)?.classList.remove('is-invalid'));
            }

            /* ── view toggle ── */
            window.setView = (mode) => {
                const grid = document.getElementById('recipesGrid');
                grid.classList.toggle('list-view', mode === 'list');
                document.getElementById('gridViewBtn').classList.toggle('active', mode === 'grid');
                document.getElementById('listViewBtn').classList.toggle('active', mode === 'list');
                localStorage.setItem('recipe_view', mode);
            };
            // restore saved view
            const savedView = localStorage.getItem('recipe_view');
            if (savedView === 'list') setView('list');

            /* ── client-side filter/search/sort ── */
            function applyFilters() {
                const q    = document.getElementById('recipeSearch').value.toLowerCase();
                const diff = document.getElementById('diffFilter').value;
                const sort = document.getElementById('sortFilter').value;
                const cards = [...document.querySelectorAll('.recipe-card')];

                let visible = cards.filter(card => {
                    const titleMatch = card.dataset.title?.includes(q) ?? true;
                    const diffMatch  = !diff || card.dataset.diff === diff;
                    return titleMatch && diffMatch;
                });

                // sort
                visible.sort((a, b) => {
                    if (sort === 'alpha')  return (a.dataset.title || '').localeCompare(b.dataset.title || '');
                    if (sort === 'oldest') return parseInt(a.dataset.date || 0) - parseInt(b.dataset.date || 0);
                    return parseInt(b.dataset.date || 0) - parseInt(a.dataset.date || 0); // newest
                });

                const grid = document.getElementById('recipesGrid');
                cards.forEach(c => c.style.display = 'none');
                visible.forEach(c => { c.style.display = ''; grid.appendChild(c); });

                const noResult = document.getElementById('noResult');
                if (noResult) noResult.style.display = visible.length === 0 ? 'block' : 'none';
            }

            let searchTimer;
            document.getElementById('recipeSearch')?.addEventListener('input', () => {
                clearTimeout(searchTimer);
                searchTimer = setTimeout(applyFilters, 300);
            });
            document.getElementById('diffFilter')?.addEventListener('change', applyFilters);
            document.getElementById('sortFilter')?.addEventListener('change', applyFilters);

            /* ══════════ CREATE ══════════ */
            window.openCreateModal = () => {
                hideAlert('createAlert');
                resetInvalid('c_title');
                ['c_title','c_desc','c_cooking','c_servings'].forEach(id => document.getElementById(id).value = '');
                document.getElementById('c_diff').value = 'Medium';
                createModal.show();
            };

            window.submitCreate = async () => {
                hideAlert('createAlert');
                const title    = document.getElementById('c_title').value.trim();
                const desc     = document.getElementById('c_desc').value.trim();
                const cooking  = document.getElementById('c_cooking').value;
                const servings = document.getElementById('c_servings').value;
                const diff     = document.getElementById('c_diff').value;

                resetInvalid('c_title');
                if (!title) { document.getElementById('c_title').classList.add('is-invalid'); return; }

                setLoading('createSubmit', true);
                try {
                    const res  = await fetch('/Recipe/Create', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            title,
                            description:     desc     || null,
                            cookingTime:     cooking  ? parseInt(cooking)  : null,
                            servings:        servings ? parseInt(servings) : null,
                            difficultyLevel: diff
                        })
                    });
                    const data = await res.json();
                    if ((res.ok && data.success) || res.ok) {
                        createModal.hide();
                        location.reload();
                    } else {
                        showAlert('createAlert', data.message || data.errors?.[0] || 'Có lỗi xảy ra');
                    }
                } catch { showAlert('createAlert', 'Không thể kết nối đến server'); }
                finally  { setLoading('createSubmit', false); }
            };

            /* ══════════ EDIT ══════════ */
            window.openEditModal = (btn) => {
                hideAlert('editAlert');
                resetInvalid('e_title');
                document.getElementById('e_id').value       = btn.dataset.id;
                document.getElementById('e_title').value    = btn.dataset.title   || '';
                document.getElementById('e_desc').value     = btn.dataset.desc    || '';
                document.getElementById('e_cooking').value  = btn.dataset.cooking || '';
                document.getElementById('e_servings').value = btn.dataset.servings|| '';
                document.getElementById('e_diff').value     = btn.dataset.diff    || 'Medium';
                editModal.show();
            };

            window.submitEdit = async () => {
                hideAlert('editAlert');
                const id       = document.getElementById('e_id').value;
                const title    = document.getElementById('e_title').value.trim();
                const desc     = document.getElementById('e_desc').value.trim();
                const cooking  = document.getElementById('e_cooking').value;
                const servings = document.getElementById('e_servings').value;
                const diff     = document.getElementById('e_diff').value;

                resetInvalid('e_title');
                if (!title) { document.getElementById('e_title').classList.add('is-invalid'); return; }

                setLoading('editSubmit', true);
                try {
                    const res  = await fetch(`/Recipe/Update/${id}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            title,
                            description:     desc     || null,
                            cookingTime:     cooking  ? parseInt(cooking)  : null,
                            servings:        servings ? parseInt(servings) : null,
                            difficultyLevel: diff
                        })
                    });
                    const data = await res.json();
                    if ((res.ok && data.success) || res.ok) {
                        editModal.hide();
                        location.reload();
                    } else {
                        showAlert('editAlert', data.message || data.errors?.[0] || 'Có lỗi xảy ra');
                    }
                } catch { showAlert('editAlert', 'Không thể kết nối đến server'); }
                finally  { setLoading('editSubmit', false); }
            };

            /* ══════════ DELETE ══════════ */
            window.openDeleteModal = (btn) => {
                document.getElementById('deleteId').value         = btn.dataset.id;
                document.getElementById('deleteTitle').textContent = btn.dataset.title || '(không tên)';
                deleteModal.show();
            };

            window.submitDelete = async () => {
                const id = document.getElementById('deleteId').value;
                setLoading('deleteSubmit', true);
                try {
                    const res  = await fetch(`/Recipe/Delete/${id}`, { method: 'DELETE' });
                    const data = await res.json();
                    if ((res.ok && data.success) || res.ok) {
                        deleteModal.hide();
                        location.reload();
                    } else {
                        alert(data.message || 'Có lỗi xảy ra khi xoá');
                    }
                } catch { alert('Không thể kết nối đến server'); }
                finally  { setLoading('deleteSubmit', false); }
            };
        })();
    </script>
}

