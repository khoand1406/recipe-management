@using RecipeMgt.Views.Models.Response
@model List<RecipeWithUserInfo>

@{
    ViewData["Title"] = "Công thức của tôi";
}

@section Styles {
    <style>
        /* ── Page wrapper ── */
        .my-recipes-page {
            padding: 40px 0 64px;
            min-height: calc(100vh - var(--nav-height));
        }

        /* ── Page header ── */
        .recipes-header {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 16px;
            margin-bottom: 32px;
            flex-wrap: wrap;
        }

        .recipes-title {
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--text);
            margin: 0;
            line-height: 1.2;
        }

            .recipes-title span {
                color: var(--brand-dark);
            }

        .recipes-subtitle {
            font-size: .875rem;
            color: var(--text-muted);
            margin: 6px 0 0;
        }

        .btn-new-recipe {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 10px 20px;
            border-radius: 50px;
            background: linear-gradient(135deg, var(--brand), var(--brand-dark));
            color: #fff;
            font-size: .875rem;
            font-weight: 600;
            border: none;
            cursor: pointer;
            text-decoration: none;
            box-shadow: 0 2px 10px rgba(245,158,11,.35);
            transition: all var(--transition);
            white-space: nowrap;
        }

            .btn-new-recipe:hover {
                transform: translateY(-2px);
                box-shadow: 0 4px 18px rgba(245,158,11,.45);
                color: #fff;
            }

        /* ── Stat bar ── */
        .stat-bar {
            display: flex;
            gap: 12px;
            margin-bottom: 28px;
            flex-wrap: wrap;
        }

        .stat-pill {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px 18px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 50px;
            font-size: .82rem;
            font-weight: 500;
            color: var(--text-muted);
            transition: all var(--transition);
        }

            .stat-pill .val {
                font-weight: 700;
                color: var(--text);
                font-size: .95rem;
            }

            .stat-pill i {
                color: var(--brand);
            }

        /* ── Toolbar ── */
        .recipes-toolbar {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }

        .toolbar-search {
            position: relative;
            flex: 1;
            min-width: 200px;
            max-width: 320px;
        }

            .toolbar-search .bi {
                position: absolute;
                left: 13px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--text-muted);
                font-size: .85rem;
                pointer-events: none;
            }

            .toolbar-search input {
                width: 100%;
                padding: 9px 14px 9px 36px;
                border: 1.5px solid var(--border);
                border-radius: 50px;
                font-size: .82rem;
                color: var(--text);
                background: var(--surface);
                outline: none;
                transition: all var(--transition);
            }

                .toolbar-search input:focus {
                    border-color: var(--brand);
                    box-shadow: 0 0 0 3px rgba(245,158,11,.12);
                }

        .toolbar-filter {
            padding: 9px 14px;
            border: 1.5px solid var(--border);
            border-radius: 50px;
            font-size: .82rem;
            color: var(--text);
            background: var(--surface);
            outline: none;
            cursor: pointer;
            transition: border var(--transition);
        }

            .toolbar-filter:focus {
                border-color: var(--brand);
            }

        .view-toggle {
            display: flex;
            gap: 4px;
            margin-left: auto;
            background: var(--surface);
            border: 1.5px solid var(--border);
            border-radius: 10px;
            padding: 3px;
        }

        .view-btn {
            width: 32px;
            height: 32px;
            border-radius: 7px;
            border: none;
            background: transparent;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .9rem;
            cursor: pointer;
            transition: all var(--transition);
        }

            .view-btn.active {
                background: var(--brand-light);
                color: var(--brand-dark);
            }

        /* ── Recipe Grid ── */
        .recipes-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px;
        }

            .recipes-grid.list-view {
                grid-template-columns: 1fr;
                gap: 12px;
            }

        /* ── Recipe Card ── */
        .recipe-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            overflow: hidden;
            transition: all var(--transition);
            position: relative;
            display: flex;
            flex-direction: column;
        }

            .recipe-card:hover {
                box-shadow: var(--shadow-md);
                transform: translateY(-3px);
                border-color: var(--brand-light);
            }

        /* Card thumbnail */
        .card-thumb {
            height: 180px;
            background: linear-gradient(135deg, #fef3c7, #fde68a);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            position: relative;
            overflow: hidden;
            flex-shrink: 0;
        }

            .card-thumb::after {
                content: '';
                position: absolute;
                inset: 0;
                background: linear-gradient(to bottom, transparent 60%, rgba(0,0,0,.12));
            }

            .card-thumb.diff-easy {
                background: linear-gradient(135deg,#d1fae5,#a7f3d0);
            }

            .card-thumb.diff-medium {
                background: linear-gradient(135deg,#fef3c7,#fde68a);
            }

            .card-thumb.diff-hard {
                background: linear-gradient(135deg,#fee2e2,#fecaca);
            }

        /* Difficulty badge on thumb */
        .diff-badge {
            position: absolute;
            top: 12px;
            left: 12px;
            padding: 3px 10px;
            border-radius: 50px;
            font-size: .68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .04em;
            backdrop-filter: blur(8px);
            z-index: 1;
        }

            .diff-badge.easy {
                background: rgba(209,250,229,.9);
                color: #065f46;
            }

            .diff-badge.medium {
                background: rgba(254,243,199,.9);
                color: #92400e;
            }

            .diff-badge.hard {
                background: rgba(254,226,226,.9);
                color: #991b1b;
            }

        /* Action menu on card */
        .card-actions-top {
            position: absolute;
            top: 10px;
            right: 10px;
            z-index: 2;
            opacity: 0;
            transition: opacity var(--transition);
        }

        .recipe-card:hover .card-actions-top {
            opacity: 1;
        }

        .card-menu-btn {
            width: 30px;
            height: 30px;
            border-radius: 8px;
            background: rgba(255,255,255,.9);
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .85rem;
            color: var(--text);
            cursor: pointer;
            backdrop-filter: blur(4px);
        }

            .card-menu-btn:hover {
                background: #fff;
            }

        /* Card body */
        .card-body-inner {
            padding: 16px;
            display: flex;
            flex-direction: column;
            flex: 1;
        }

        .card-title {
            font-size: .95rem;
            font-weight: 700;
            color: var(--text);
            margin: 0 0 6px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            line-height: 1.4;
        }

        .card-desc {
            font-size: .78rem;
            color: var(--text-muted);
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            line-height: 1.5;
            flex: 1;
        }

        /* Card meta chips */
        .card-meta {
            display: flex;
            gap: 8px;
            margin-top: 14px;
            flex-wrap: wrap;
        }

        .meta-chip {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: .72rem;
            color: var(--text-muted);
            background: var(--bg);
            border: 1px solid var(--border);
            padding: 3px 9px;
            border-radius: 50px;
        }

            .meta-chip i {
                font-size: .7rem;
                color: var(--brand);
            }

        /* Card footer */
        .card-footer-inner {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 16px;
            border-top: 1px solid var(--border);
            background: var(--bg);
        }

        .card-date {
            font-size: .72rem;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .card-btns {
            display: flex;
            gap: 4px;
        }

        .cb {
            width: 28px;
            height: 28px;
            border-radius: 7px;
            border: 1px solid var(--border);
            background: var(--surface);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .75rem;
            cursor: pointer;
            color: var(--text-muted);
            transition: all var(--transition);
            text-decoration: none;
        }

            .cb:hover {
                background: var(--brand-light);
                border-color: var(--brand);
                color: var(--brand-dark);
            }

            .cb.cb-del:hover {
                background: #fef2f2;
                border-color: #fecaca;
                color: #dc2626;
            }

        /* ── List view card ── */
        .recipes-grid.list-view .recipe-card {
            flex-direction: row;
            align-items: stretch;
        }

        .recipes-grid.list-view .card-thumb {
            width: 120px;
            height: auto;
            min-height: 100px;
            flex-shrink: 0;
            font-size: 2rem;
            border-radius: 0;
        }

        .recipes-grid.list-view .card-actions-top {
            display: none;
        }

        .recipes-grid.list-view .card-body-inner {
            padding: 14px 16px 10px;
        }

        .recipes-grid.list-view .card-footer-inner {
            border-top: none;
            border-left: 1px solid var(--border);
            flex-direction: column;
            justify-content: center;
            gap: 8px;
            padding: 14px 16px;
            min-width: 100px;
            background: var(--bg);
            flex-shrink: 0;
        }

        .recipes-grid.list-view .card-btns {
            flex-direction: column;
        }

        /* ── Empty state ── */
        .empty-state {
            grid-column: 1/-1;
            text-align: center;
            padding: 80px 20px;
        }

        .empty-icon {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: var(--brand-light);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            margin: 0 auto 20px;
        }

        .empty-title {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 8px;
        }

        .empty-sub {
            font-size: .85rem;
            color: var(--text-muted);
            margin-bottom: 24px;
        }

        /* ── Modal styles ── */
        .modal-content {
            border-radius: 16px !important;
            border: none !important;
            box-shadow: var(--shadow-lg) !important;
        }

        .modal-header {
            border-bottom: 1px solid var(--border) !important;
            padding: 20px 24px 16px;
        }

        .modal-footer {
            border-top: 1px solid var(--border) !important;
            padding: 16px 24px 20px;
        }

        .modal-body {
            padding: 20px 24px;
        }

        .modal-title {
            font-size: 1rem;
            font-weight: 700;
            color: var(--text);
        }

        .m-form-group {
            margin-bottom: 16px;
        }

        .m-label {
            display: block;
            font-size: .78rem;
            font-weight: 600;
            color: #374151;
            margin-bottom: 6px;
        }

            .m-label .req {
                color: #ef4444;
                margin-left: 2px;
            }

        .m-input {
            width: 100%;
            padding: 9px 14px;
            border: 1.5px solid var(--border);
            border-radius: 10px;
            font-size: .85rem;
            color: var(--text);
            background: var(--bg);
            outline: none;
            transition: all var(--transition);
        }

            .m-input:focus {
                border-color: var(--brand);
                box-shadow: 0 0 0 3px rgba(245,158,11,.12);
                background: #fff;
            }

            .m-input.is-invalid {
                border-color: #ef4444;
            }

        .m-invalid {
            font-size: .75rem;
            color: #ef4444;
            margin-top: 4px;
            display: none;
        }

        .m-input.is-invalid ~ .m-invalid {
            display: block;
        }

        .m-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        .m-alert {
            padding: 10px 14px;
            border-radius: 9px;
            font-size: .8rem;
            margin-bottom: 16px;
            display: none;
        }

            .m-alert.error {
                background: #fef2f2;
                color: #dc2626;
                border: 1px solid #fecaca;
            }

            .m-alert.show {
                display: block;
            }

        .spinner-sm {
            width: 14px;
            height: 14px;
            border: 2px solid rgba(255,255,255,.4);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin .6s linear infinite;
            display: none;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .btn-loading .spinner-sm {
            display: inline-block;
        }

        .btn-loading .btn-text {
            display: none;
        }

        .delete-icon-box {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: #fef2f2;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 16px;
            font-size: 1.5rem;
            color: #ef4444;
        }

        .btn-brand {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 9px 20px;
            border-radius: 50px;
            background: linear-gradient(135deg, var(--brand), var(--brand-dark));
            color: #fff;
            font-size: .85rem;
            font-weight: 600;
            border: none;
            cursor: pointer;
            transition: all var(--transition);
        }

            .btn-brand:hover {
                opacity: .88;
                color: #fff;
                transform: translateY(-1px);
            }

        .btn-ghost {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 9px 16px;
            border-radius: 50px;
            border: 1.5px solid var(--border);
            color: var(--text-muted);
            background: transparent;
            font-size: .85rem;
            font-weight: 500;
            cursor: pointer;
            transition: all var(--transition);
        }

            .btn-ghost:hover {
                border-color: var(--brand);
                color: var(--brand-dark);
                background: var(--brand-light);
            }

        @@media (max-width: 576px) {
            .recipes-grid {
                grid-template-columns: 1fr;
            }

            .m-row {
                grid-template-columns: 1fr;
            }

            .recipes-grid.list-view .card-footer-inner {
                flex-direction: row;
                border: none;
                border-top: 1px solid var(--border);
                min-width: unset;
            }

            .recipes-grid.list-view .recipe-card {
                flex-direction: column;
            }

            .recipes-grid.list-view .card-thumb {
                width: 100%;
                height: 140px;
            }
        }
    </style>
}

<div class="my-recipes-page">
    <div class="container">

        @* ── Header ── *@
        <div class="recipes-header">
            <div>
                <h1 class="recipes-title">Công thức <span>của tôi</span></h1>
                <p class="recipes-subtitle">Quản lý và chia sẻ những công thức nấu ăn bạn đã tạo</p>
            </div>
            <button class="btn-new-recipe" onclick="openCreateModal()">
                <i class="bi bi-plus-lg"></i> Tạo công thức mới
            </button>
        </div>

        @* ── Stats ── *@
        @{
            var total = Model?.Count ?? 0;
            var easy = Model?.Count(r => r.DifficultyLevel?.ToLower() == "easy") ?? 0;
            var medium = Model?.Count(r => r.DifficultyLevel?.ToLower() == "medium") ?? 0;
            var hard = Model?.Count(r => r.DifficultyLevel?.ToLower() == "hard") ?? 0;
        }
        <div class="stat-bar">
            <div class="stat-pill">
                <i class="bi bi-journal-richtext"></i>
                <span class="val">@total</span> công thức
            </div>
            <div class="stat-pill">
                <i class="bi bi-emoji-smile" style="color:#22c55e;"></i>
                <span class="val">@easy</span> dễ
            </div>
            <div class="stat-pill">
                <i class="bi bi-fire" style="color:var(--brand);"></i>
                <span class="val">@medium</span> trung bình
            </div>
            <div class="stat-pill">
                <i class="bi bi-lightning-charge" style="color:#ef4444;"></i>
                <span class="val">@hard</span> khó
            </div>
        </div>

        @* ── Toolbar ── *@
        <div class="recipes-toolbar">
            <div class="toolbar-search">
                <i class="bi bi-search"></i>
                <input type="text" id="recipeSearch" placeholder="Tìm công thức…" autocomplete="off" />
            </div>

            <select class="toolbar-filter" id="diffFilter">
                <option value="">Tất cả độ khó</option>
                <option value="easy">Dễ</option>
                <option value="medium">Trung bình</option>
                <option value="hard">Khó</option>
            </select>

            <select class="toolbar-filter" id="sortFilter">
                <option value="newest">Mới nhất</option>
                <option value="oldest">Cũ nhất</option>
                <option value="alpha">A → Z</option>
            </select>

            <div class="view-toggle">
                <button class="view-btn active" id="gridViewBtn" title="Dạng lưới" onclick="setView('grid')">
                    <i class="bi bi-grid"></i>
                </button>
                <button class="view-btn" id="listViewBtn" title="Dạng danh sách" onclick="setView('list')">
                    <i class="bi bi-list-ul"></i>
                </button>
            </div>
        </div>

        @* ── Grid ── *@
        <div class="recipes-grid" id="recipesGrid">
            @if (Model != null && Model.Any())
            {
                @foreach (var r in Model)
                {
                    var diff = r.DifficultyLevel?.ToLower() ?? "";
                    var diffLabel = diff switch { "easy" => "Dễ", "medium" => "Trung bình", "hard" => "Khó", _ => r.DifficultyLevel ?? "" };
                    var diffClass = diff switch { "easy" => "easy", "medium" => "medium", "hard" => "hard", _ => "medium" };
                    var emoji = diff switch { "easy" => "🥗", "hard" => "🔥", _ => "🍳" };

                    <div class="recipe-card"
                         data-title="@r.Title.ToLower()"
                         data-diff="@diff"
                         data-date="@r.CreatedAt?.Ticks">

                        <div class="card-thumb diff-@diffClass">
                            <span>@emoji</span>
                            @if (!string.IsNullOrEmpty(diffLabel))
                            {
                                <span class="diff-badge @diffClass">@diffLabel</span>
                            }
                            <div class="card-actions-top">
                                <div class="dropdown">
                                    <button class="card-menu-btn" data-bs-toggle="dropdown">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end" style="min-width:150px;border-radius:10px;">
                                        <li>
                                            <button class="dropdown-item"
                                                    data-id="@r.RecipeId"
                                                    data-title="@r.Title"
                                                    data-desc="@r.Description"
                                                    data-cooking="@r.CookingTime"
                                                    data-servings="@r.Servings"
                                                    data-diff="@r.DifficultyLevel"
                                                    onclick="openEditModal(this)">
                                                <i class="bi bi-pencil"></i> Chỉnh sửa
                                            </button>
                                        </li>
                                        <li>
                                            <button class="dropdown-item text-danger"
                                                    data-id="@r.RecipeId"
                                                    data-title="@r.Title"
                                                    onclick="openDeleteModal(this)">
                                                <i class="bi bi-trash"></i> Xoá
                                            </button>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <div class="card-body-inner">
                            <div class="card-title">@r.Title</div>
                            <div class="card-desc">@(string.IsNullOrWhiteSpace(r.Description) ? "Chưa có mô tả" : r.Description)</div>
                            <div class="card-meta">
                                @if (r.CookingTime.HasValue)
                                {
                                    <span class="meta-chip"><i class="bi bi-clock"></i> @r.CookingTime phút</span>
                                }
                                @if (r.Servings.HasValue)
                                {
                                    <span class="meta-chip"><i class="bi bi-people"></i> @r.Servings người</span>
                                }
                            </div>
                        </div>

                        <div class="card-footer-inner">
                            <span class="card-date">
                                <i class="bi bi-calendar3"></i>
                                @(r.CreatedAt.HasValue? r.CreatedAt.Value.ToString("dd/MM/yyyy") : "—")
                            </span>
                            <div class="card-btns">
                                <a href="/Recipe/Detail/@r.RecipeId" class="cb" title="Xem">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <button class="cb" title="Chỉnh sửa"
                                        data-id="@r.RecipeId"
                                        data-title="@r.Title"
                                        data-desc="@r.Description"
                                        data-cooking="@r.CookingTime"
                                        data-servings="@r.Servings"
                                        data-diff="@r.DifficultyLevel"
                                        onclick="openEditModal(this)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="cb cb-del" title="Xoá"
                                        data-id="@r.RecipeId"
                                        data-title="@r.Title"
                                        onclick="openDeleteModal(this)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-icon">🍳</div>
                    <div class="empty-title">Chưa có công thức nào</div>
                    <p class="empty-sub">Hãy tạo công thức đầu tiên và chia sẻ với mọi người!</p>
                    <button class="btn-brand" onclick="openCreateModal()">
                        <i class="bi bi-plus-lg"></i> Tạo ngay
                    </button>
                </div>
            }

            @* No result after filter *@
            <div class="empty-state" id="noResult" style="display:none;">
                <div class="empty-icon">🔍</div>
                <div class="empty-title">Không tìm thấy công thức</div>
                <p class="empty-sub">Thử tìm kiếm với từ khoá khác.</p>
            </div>
        </div>

    </div>
</div>

@* ══════════ CREATE MODAL ══════════ *@
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width:540px;">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-plus-circle me-2" style="color:var(--brand);"></i>Tạo công thức mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="m-alert error" id="createAlert"></div>
                <div class="m-form-group">
                    <label class="m-label">Tên công thức <span class="req">*</span></label>
                    <input type="text" class="m-input" id="c_title" placeholder="VD: Phở bò truyền thống" maxlength="200" />
                    <div class="m-invalid">Tên công thức không được để trống</div>
                </div>
                <div class="m-form-group">
                    <label class="m-label">Mô tả</label>
                    <textarea class="m-input" id="c_desc" rows="3" placeholder="Mô tả ngắn về công thức…" style="resize:vertical"></textarea>
                </div>
                <div class="m-row">
                    <div class="m-form-group">
                        <label class="m-label">Thời gian nấu (phút)</label>
                        <input type="number" class="m-input" id="c_cooking" placeholder="30" min="1" max="9999" />
                    </div>
                    <div class="m-form-group">
                        <label class="m-label">Khẩu phần (người)</label>
                        <input type="number" class="m-input" id="c_servings" placeholder="4" min="1" max="999" />
                    </div>
                </div>
                <div class="m-form-group">
                    <label class="m-label">Độ khó</label>
                    <select class="m-input" id="c_diff">
                        <option value="Easy">Dễ</option>
                        <option value="Medium" selected>Trung bình</option>
                        <option value="Hard">Khó</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-ghost" data-bs-dismiss="modal">Huỷ</button>
                <button type="button" class="btn-brand" id="createSubmit" onclick="submitCreate()">
                    <span class="spinner-sm"></span>
                    <span class="btn-text"><i class="bi bi-plus-lg me-1"></i>Tạo công thức</span>
                </button>
            </div>
        </div>
    </div>
</div>

@* ══════════ EDIT MODAL ══════════ *@
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width:540px;">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-pencil-square me-2"></i>Chỉnh sửa công thức</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="m-alert error" id="editAlert"></div>
                <input type="hidden" id="e_id" />
                <div class="m-form-group">
                    <label class="m-label">Tên công thức <span class="req">*</span></label>
                    <input type="text" class="m-input" id="e_title" maxlength="200" />
                    <div class="m-invalid">Tên công thức không được để trống</div>
                </div>
                <div class="m-form-group">
                    <label class="m-label">Mô tả</label>
                    <textarea class="m-input" id="e_desc" rows="3" style="resize:vertical"></textarea>
                </div>
                <div class="m-row">
                    <div class="m-form-group">
                        <label class="m-label">Thời gian nấu (phút)</label>
                        <input type="number" class="m-input" id="e_cooking" min="1" max="9999" />
                    </div>
                    <div class="m-form-group">
                        <label class="m-label">Khẩu phần (người)</label>
                        <input type="number" class="m-input" id="e_servings" min="1" max="999" />
                    </div>
                </div>
                <div class="m-form-group">
                    <label class="m-label">Độ khó</label>
                    <select class="m-input" id="e_diff">
                        <option value="Easy">Dễ</option>
                        <option value="Medium">Trung bình</option>
                        <option value="Hard">Khó</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-ghost" data-bs-dismiss="modal">Huỷ</button>
                <button type="button" class="btn-brand" id="editSubmit" onclick="submitEdit()">
                    <span class="spinner-sm"></span>
                    <span class="btn-text"><i class="bi bi-check-lg me-1"></i>Lưu thay đổi</span>
                </button>
            </div>
        </div>
