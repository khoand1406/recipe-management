@{
    ViewData["Title"] = "Đăng ký";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CookPad</title>

    <!-- Bootstrap & Icons -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/register.css" />
</head>

<body>
    <div class="auth-card">

        <!-- ══════════════ LEFT PANEL ══════════════ -->
        <div class="auth-panel">
            <div class="panel-logo">🍳</div>
            <div class="panel-title">CookPad</div>
            <p class="panel-subtitle">
                Tham gia cộng đồng đầu bếp<br>
                đam mê nấu ăn hôm nay
            </p>

            <div class="panel-steps">
                <div class="step-item">
                    <div class="step-num">1</div>
                    <div class="step-text">
                        <strong>Tạo tài khoản</strong>
                        Điền thông tin cơ bản
                    </div>
                </div>
                <div class="step-item">
                    <div class="step-num">2</div>
                    <div class="step-text">
                        <strong>Xác thực Email</strong>
                        Xác nhận địa chỉ email
                    </div>
                </div>
                <div class="step-item">
                    <div class="step-num">3</div>
                    <div class="step-text">
                        <strong>Bắt đầu nấu ăn</strong>
                        Khám phá & chia sẻ công thức
                    </div>
                </div>
            </div>
        </div>

        <!-- ══════════════ RIGHT PANEL ══════════════ -->
        <div class="auth-form-wrap">
            <div class="form-header">
                <h1>Tạo tài khoản mới ✨</h1>
                <p>Miễn phí · Không cần thẻ tín dụng</p>
            </div>

            <!-- Server error -->
            @if (ViewBag.Error != null)
            {
                <div class="alert-error">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    @ViewBag.Error
                </div>
            }

            <!-- Social Register -->
            <div class="social-grid">
                <a href="/Auth/RegisterGoogle" class="btn-social">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                    </svg>
                    Google
                </a>
                <a href="/Auth/RegisterMicrosoft" class="btn-social">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M11.4 2H2v9.4h9.4V2z" fill="#F25022"/>
                        <path d="M22 2h-9.4v9.4H22V2z" fill="#7FBA00"/>
                        <path d="M11.4 12.6H2V22h9.4v-9.4z" fill="#00A4EF"/>
                        <path d="M22 12.6h-9.4V22H22v-9.4z" fill="#FFB900"/>
                    </svg>
                    Microsoft
                </a>
            </div>

            <div class="divider">hoặc đăng ký bằng email</div>

            <!-- Register Form -->
            <form action="@Url.RouteUrl("AuthRegister")"
                  method="post"
                  id="registerForm"
                  novalidate>

                <!-- Row 1: Username + Email -->
                <div class="form-row">
                    <!-- Username -->
                    <div class="field">
                        <label class="field-label" for="username">Tên người dùng</label>
                        <input type="text"
                               class="field-input"
                               id="username"
                               name="username"
                               placeholder="cookmaster99"
                               autocomplete="username"
                               required />
                        <i class="bi bi-person field-icon"></i>
                        <i class="bi bi-check-circle-fill field-check"></i>
                        <div class="field-error" id="usernameError" style="display:none">
                            <i class="bi bi-exclamation-circle"></i><span></span>
                        </div>
                    </div>

                    <!-- Email -->
                    <div class="field">
                        <label class="field-label" for="email">Địa chỉ Email</label>
                        <input type="email"
                               class="field-input"
                               id="email"
                               name="email"
                               placeholder="you@example.com"
                               autocomplete="email"
                               required />
                        <i class="bi bi-envelope field-icon"></i>
                        <i class="bi bi-check-circle-fill field-check"></i>
                        <div class="field-error" id="emailError" style="display:none">
                            <i class="bi bi-exclamation-circle"></i><span></span>
                        </div>
                    </div>
                </div>

                <!-- Password -->
                <div class="field">
                    <label class="field-label" for="password">Mật khẩu</label>
                    <input type="password"
                           class="field-input"
                           id="password"
                           name="password"
                           placeholder="Tối thiểu 8 ký tự"
                           autocomplete="new-password"
                           style="padding-right:2.65rem"
                           required />
                    <i class="bi bi-lock field-icon"></i>
                    <button type="button" class="field-toggle" id="togglePassword">
                        <i class="bi bi-eye" id="eyeIcon1"></i>
                    </button>

                    <!-- Strength meter -->
                    <div class="strength-wrap" id="strengthWrap" style="display:none">
                        <div class="strength-bars">
                            <div class="strength-bar" id="bar1"></div>
                            <div class="strength-bar" id="bar2"></div>
                            <div class="strength-bar" id="bar3"></div>
                            <div class="strength-bar" id="bar4"></div>
                        </div>
                        <span class="strength-label" id="strengthLabel"></span>

                        <div class="pwd-rules">
                            <div class="pwd-rule" id="rule-length">
                                <i class="rule-icon"></i> Ít nhất 8 ký tự
                            </div>
                            <div class="pwd-rule" id="rule-upper">
                                <i class="rule-icon"></i> Có chữ hoa (A–Z)
                            </div>
                            <div class="pwd-rule" id="rule-number">
                                <i class="rule-icon"></i> Có chữ số (0–9)
                            </div>
                            <div class="pwd-rule" id="rule-special">
                                <i class="rule-icon"></i> Có ký tự đặc biệt (!@@#$…)
                            </div>
                        </div>
                    </div>

                    <div class="field-error" id="passwordError" style="display:none">
                        <i class="bi bi-exclamation-circle"></i><span></span>
                    </div>
                </div>

                <!-- Confirm Password -->
                <div class="field">
                    <label class="field-label" for="confirmPassword">Xác nhận mật khẩu</label>
                    <input type="password"
                           class="field-input"
                           id="confirmPassword"
                           name="confirmPassword"
                           placeholder="Nhập lại mật khẩu"
                           autocomplete="new-password"
                           style="padding-right:2.65rem"
                           required />
                    <i class="bi bi-shield-lock field-icon"></i>
                    <button type="button" class="field-toggle" id="toggleConfirm">
                        <i class="bi bi-eye" id="eyeIcon2"></i>
                    </button>
                    <i class="bi bi-check-circle-fill field-check" id="confirmCheck"
                       style="right:2.65rem"></i>
                    <div class="field-error" id="confirmError" style="display:none">
                        <i class="bi bi-exclamation-circle"></i><span></span>
                    </div>
                </div>

                <!-- Terms -->
                <div class="terms-wrap">
                    <input type="checkbox" id="agreeTerms" name="agreeTerms" required />
                    <label class="terms-text" for="agreeTerms">
                        Tôi đồng ý với
                        <a href="/terms" target="_blank">Điều khoản dịch vụ</a>
                        và
                        <a href="/privacy" target="_blank">Chính sách bảo mật</a>
                        của CookPad
                    </label>
                </div>
                <div class="field-error" id="termsError" style="display:none; margin-bottom:.75rem">
                    <i class="bi bi-exclamation-circle"></i><span></span>
                </div>

                <!-- General client error -->
                <div class="alert-error" id="clientError" style="display:none">
                    <i class="bi bi-exclamation-circle-fill"></i><span></span>
                </div>

                <!-- Submit -->
                <button type="submit" class="btn-submit" id="btnSubmit">
                    Tạo tài khoản
                </button>
            </form>

            <div class="login-link">
                Đã có tài khoản?
                <a asp-controller="Auth" asp-action="Login">Đăng nhập ngay</a>
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/register.js"></script>
</body>
</html>
