@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CookPad</title>

    <!-- Bootstrap & Icons -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/login.css" />
    
</head>

<body>
    <div class="auth-card">

        <!-- ══════════ LEFT PANEL ══════════ -->
        <div class="auth-panel">
            <div class="panel-logo">🍳</div>
            <div class="panel-title">CookPad</div>
            <p class="panel-subtitle">
                Khám phá hàng ngàn công thức<br>nấu ăn ngon mỗi ngày
            </p>
            <div class="panel-features">
                <div class="panel-feature">
                    <i class="bi bi-journal-bookmark-fill"></i>
                    Lưu công thức yêu thích
                </div>
                <div class="panel-feature">
                    <i class="bi bi-people-fill"></i>
                    Kết nối cộng đồng đầu bếp
                </div>
                <div class="panel-feature">
                    <i class="bi bi-star-fill"></i>
                    Đánh giá & chia sẻ trải nghiệm
                </div>
            </div>
        </div>

        <!-- ══════════ RIGHT PANEL (FORM) ══════════ -->
        <div class="auth-form-wrap">
            <div class="form-header">
                <h1>Chào mừng trở lại</h1>
                <p>Đăng nhập để tiếp tục trải nghiệm CookPad</p>
            </div>

            <!-- Server-side error -->
            @if (ViewBag.Error != null)
            {
                <div class="alert-error">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    @ViewBag.Error
                </div>
            }

            <!-- ── Social Login ── -->
            <div class="social-grid">

                <!-- Google -->
                <a href="/Auth/LoginGoogle" class="btn-social" id="btnGoogle">
                    <!-- Official Google logo SVG -->
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                    </svg>
                    Google
                </a>

                <!-- Microsoft (Outlook) -->
                <a href="/Auth/LoginMicrosoft" class="btn-social" id="btnMicrosoft">
                    <!-- Official Microsoft logo SVG -->
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M11.4 2H2v9.4h9.4V2z" fill="#F25022"/>
                        <path d="M22 2h-9.4v9.4H22V2z" fill="#7FBA00"/>
                        <path d="M11.4 12.6H2V22h9.4v-9.4z" fill="#00A4EF"/>
                        <path d="M22 12.6h-9.4V22H22v-9.4z" fill="#FFB900"/>
                    </svg>
                    Microsoft
                </a>
            </div>

            <!-- Divider -->
            <div class="divider">hoặc đăng nhập bằng email</div>

            <!-- ── Email / Password Form ── -->
            <form asp-controller="Auth"
                  asp-action="Login"
                  method="post"
                  id="loginForm"
                  novalidate>

                <!-- Email -->
                <div class="field">
                    <label class="field-label" for="email">Địa chỉ Email</label>
                    <input type="email"
                           class="field-input"
                           id="email"
                           name="email"
                           placeholder="you@example.com"
                           autocomplete="email"
                           required />
                    <i class="bi bi-envelope field-icon"></i>
                    <div class="field-error" id="emailError" style="display:none">
                        <i class="bi bi-exclamation-circle"></i>
                        <span></span>
                    </div>
                </div>

                <!-- Password -->
                <div class="field">
                    <label class="field-label" for="password">Mật khẩu</label>
                    <input type="password"
                           class="field-input"
                           id="password"
                           name="password"
                           placeholder="••••••••"
                           autocomplete="current-password"
                           style="padding-right:2.75rem"
                           required />
                    <i class="bi bi-lock field-icon"></i>
                    <button type="button"
                            class="field-toggle"
                            id="togglePassword"
                            aria-label="Hiện/ẩn mật khẩu">
                        <i class="bi bi-eye" id="eyeIcon"></i>
                    </button>
                    <div class="field-error" id="passwordError" style="display:none">
                        <i class="bi bi-exclamation-circle"></i>
                        <span></span>
                    </div>
                </div>

                <!-- Remember me + Forgot password -->
                <div class="extras-row">
                    <label class="check-label">
                        <input type="checkbox" name="rememberMe" />
                        Ghi nhớ đăng nhập
                    </label>
                    <a href="/Auth/ForgotPassword" class="forgot-link">Quên mật khẩu?</a>
                </div>

                <!-- Client error -->
                <div class="alert-error" id="clientError" style="display:none">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    <span></span>
                </div>

                <!-- Submit -->
                <button type="submit" class="btn-submit" id="btnSubmit">
                    Đăng nhập
                </button>
            </form>

            <!-- Register -->
            <div class="register-link">
                Chưa có tài khoản?
                <a asp-controller="Auth" asp-action="Register">Tạo tài khoản miễn phí</a>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/login.js"></script> 
</body>
</html>
