@model RecipeMgt.Views.Models.ViewModels.HomeViewModel

@{
    ViewData["Title"] = "Trang chủ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="hero-section">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>

    <div class="container hero-content">
        <div class="hero-badge">
            <i class="bi bi-fire"></i> Cộng đồng nấu ăn #1 Việt Nam
        </div>

        <h1 class="hero-title">
            Nấu ngon mỗi ngày<br>
            <span class="hero-highlight">cùng CookPad</span>
        </h1>

        <p class="hero-sub">
            Khám phá hàng ngàn công thức từ các đầu bếp đam mê khắp Việt Nam
        </p>

        <!-- Search -->
        
        <!-- Quick tags -->
        <div class="hero-tags">
            <span class="hero-tag-label">Phổ biến:</span>
            <a href="/Recipe/Search?query=Phở" class="hero-tag">Phở</a>
            <a href="/Recipe/Search?query=Bún bò" class="hero-tag">Bún bò</a>
            <a href="/Recipe/Search?query=Bánh mì" class="hero-tag">Bánh mì</a>
            <a href="/Recipe/Search?query=Cơm tấm" class="hero-tag">Cơm tấm</a>
        </div>
    </div>

    <!-- Scroll cue -->
    <div class="hero-scroll-cue">
        <i class="bi bi-chevron-double-down"></i>
    </div>
</section>

<!-- ══════════════════════════════════════
     STATS BAR
══════════════════════════════════════ -->
<section class="stats-bar">
    <div class="container">
        <div class="stats-grid">
            <div class="stat-item">
                <i class="bi bi-journal-richtext stat-icon"></i>
                <div>
                    <div class="stat-num" data-target="12400">0</div>
                    <div class="stat-label">Công thức</div>
                </div>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <i class="bi bi-people-fill stat-icon"></i>
                <div>
                    <div class="stat-num" data-target="8500">0</div>
                    <div class="stat-label">Đầu bếp</div>
                </div>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <i class="bi bi-grid-fill stat-icon"></i>
                <div>
                    <div class="stat-num" data-target="48">0</div>
                    <div class="stat-label">Danh mục</div>
                </div>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <i class="bi bi-star-fill stat-icon"></i>
                <div>
                    <div class="stat-num" data-target="96000">0</div>
                    <div class="stat-label">Đánh giá</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════
     CATEGORY PILLS
══════════════════════════════════════ -->
<section class="section-gap">
    <div class="container">
        <div class="section-header reveal">
            <div>
                <div class="section-eyebrow">Danh mục</div>
                <h2 class="section-title">Khám phá theo chủ đề</h2>
            </div>
            <a asp-controller="Category" asp-action="Index" class="btn-text-link">
                Xem tất cả <i class="bi bi-arrow-right"></i>
            </a>
        </div>

        <!-- Horizontal scroll pills -->
        <div class="category-pills-wrap reveal">
            <div class="category-pills" id="categoryPills">
                @foreach (var category in Model.Categories)
                {
                    <a asp-controller="Dish"
                       asp-action="ByCategory"
                       asp-route-id="@category.CategoryId"
                       class="category-pill"
                       style="--pill-bg: url('@category.ImageUrl')">
                        <div class="pill-img"></div>
                        <div class="pill-overlay"></div>
                        <span class="pill-name">@category.CategoryName</span>
                    </a>
                }
            </div>
        </div>
    </div>
</section>

<section class="section-gap bg-tinted">
    <div class="container">
        <div class="section-header reveal">
            <div>
                <div class="section-eyebrow">Nổi bật</div>
                <h2 class="section-title">Top lượt xem</h2>
            </div>
            <a asp-controller="Recipe" asp-action="Index" class="btn-text-link">
                Xem thêm <i class="bi bi-arrow-right"></i>
            </a>
        </div>

        <div class="recipe-grid">
            @{
                bool isFirst = true;
            }
            @foreach (var dish in Model.TopDishes)
            {
                <div class="recipe-card reveal @(isFirst ? "recipe-card--featured" : "")">
                    <a asp-controller="Dish"
                       asp-action="Detail"
                       asp-route-id="@dish.DishId"
                       class="recipe-card-inner">

                        <!-- Image -->
                        <div class="recipe-img-wrap">
                            <img src="@dish.ImageUrls.FirstOrDefault()"
                                 alt="@dish.DishName"
                                 class="recipe-img"
                                 loading="lazy" />
                            <div class="recipe-img-overlay"></div>

                            <!-- Badges -->
                            <div class="recipe-badges">
                                @if (isFirst)
                                {
                                    <span class="badge-hot">
                                        <i class="bi bi-fire"></i> Hot #1
                                    </span>
                                }
                                <span class="badge-bookmark">
                                    <i class="bi bi-bookmark-heart"></i>
                                </span>
                            </div>

                            <!-- Quick info overlay -->
                            @if (isFirst)
                            {
                                <div class="recipe-quick-info">
                                    <span><i class="bi bi-clock"></i> 30 phút</span>
                                    <span><i class="bi bi-people"></i> 2 người</span>
                                </div>
                            }
                        </div>

                        <!-- Body -->
                        <div class="recipe-body">
                            <h3 class="recipe-name">@dish.DishName</h3>

                            <!-- Star rating (static demo) -->
                            <div class="recipe-rating">
                                <span class="stars">★★★★★</span>
                                <span class="rating-count">(4.8)</span>
                            </div>

                            <div class="recipe-meta">
                                <span class="meta-chip">
                                    <i class="bi bi-eye"></i>
                                    @dish.BookmarkCount.ToString("N0") lượt xem
                                </span>
                                <span class="meta-chip meta-chip--warm">
                                    <i class="bi bi-clock"></i> 30 phút
                                </span>
                            </div>
                        </div>
                    </a>
                </div>

                isFirst = false;
            }
        </div>
    </div>
</section>

<section class="section-gap">
    <div class="container">
        <div class="section-header reveal">
            <div>
                <div class="section-eyebrow">Mới nhất</div>
                <h2 class="section-title">Công thức mới hôm nay</h2>
            </div>
            <a asp-controller="Recipe" asp-action="Index" class="btn-text-link">
                Xem tất cả <i class="bi bi-arrow-right"></i>
            </a>
        </div>

        <div class="list-recipe-grid reveal">
            @foreach (var dish in Model.TopDishes.Take(4))
            {
                <a asp-controller="Dish"
                   asp-action="Detail"
                   asp-route-id="@dish.DishId"
                   class="list-recipe-card">
                    <div class="list-recipe-img-wrap">
                        <img src="@dish.ImageUrls.FirstOrDefault()"
                             alt="@dish.DishName"
                             loading="lazy" />
                    </div>
                    <div class="list-recipe-info">
                        <h4 class="list-recipe-name">@dish.DishName</h4>
                        <div class="list-recipe-meta">
                            <span><i class="bi bi-clock"></i> 30 phút</span>
                            <span><i class="bi bi-eye"></i> @dish.BookmarkCount lượt xem</span>
                        </div>
                        <div class="stars" style="font-size:.8rem">★★★★☆</div>
                    </div>
                    <i class="bi bi-chevron-right list-recipe-arrow"></i>
                </a>
            }
        </div>
    </div>
</section>

<section class="cta-section reveal">
    <div class="cta-bg"></div>
    <div class="container cta-content">
        <div class="cta-emoji">🍽️</div>
        <h2 class="cta-title">Bạn có công thức bí truyền?</h2>
        <p class="cta-sub">
            Chia sẻ với cộng đồng hơn <strong>8.500</strong> đầu bếp đang chờ đón!
        </p>
        <div class="cta-actions">
            <a asp-controller="Recipe" asp-action="Create" class="cta-btn-primary">
                <i class="bi bi-plus-circle-fill"></i> Đăng công thức ngay
            </a>
            <a asp-controller="Auth" asp-action="Register" class="cta-btn-secondary">
                Tham gia miễn phí
            </a>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // ── Scroll reveal ────────────────────────────────
        const revealEls = document.querySelectorAll('.reveal');
        const observer  = new IntersectionObserver((entries) => {
            entries.forEach((entry, i) => {
                if (entry.isIntersecting) {
                    // Stagger delay based on sibling index
                    const siblings = [...entry.target.parentElement.querySelectorAll('.reveal')];
                    const idx      = siblings.indexOf(entry.target);
                    entry.target.style.transitionDelay = (idx * 60) + 'ms';
                    entry.target.classList.add('visible');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.12 });

        revealEls.forEach(el => observer.observe(el));


        const counters = document.querySelectorAll('.stat-num');
        const cObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (!entry.isIntersecting) return;
                const el     = entry.target;
                const target = +el.dataset.target;
                const duration = 1600;
                const step   = target / (duration / 16);
                let current  = 0;

                const tick = () => {
                    current += step;
                    if (current < target) {
                        el.textContent = Math.floor(current).toLocaleString('vi-VN');
                        requestAnimationFrame(tick);
                    } else {
                        el.textContent = target.toLocaleString('vi-VN') + '+';
                    }
                };
                tick();
                cObserver.unobserve(el);
            });
        }, { threshold: 0.5 });

        counters.forEach(el => cObserver.observe(el));

        // ── Category pills drag scroll ───────────────────
        const pills   = document.getElementById('categoryPills');
        let isDown    = false, startX, scrollLeft;

        if (pills) {
            pills.addEventListener('mousedown', e => {
                isDown     = true;
                startX     = e.pageX - pills.offsetLeft;
                scrollLeft = pills.scrollLeft;
                pills.style.cursor = 'grabbing';
            });

            ['mouseleave','mouseup'].forEach(ev =>
                pills.addEventListener(ev, () => { isDown = false; pills.style.cursor = 'grab'; })
            );

            pills.addEventListener('mousemove', e => {
                if (!isDown) return;
                e.preventDefault();
                const x = e.pageX - pills.offsetLeft;
                pills.scrollLeft = scrollLeft - (x - startX) * 1.2;
            });

            pills.style.cursor = 'grab';
        }
    </script>
}
