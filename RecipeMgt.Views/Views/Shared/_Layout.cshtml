@inject IHttpContextAccessor HttpContextAccessor
@{
    var token = HttpContextAccessor.HttpContext?.Session.GetString("JwtToken");
    var userName = HttpContextAccessor.HttpContext?.Session.GetString("UserName");
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CookPad</title>
    <base href="/">

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap & Icons -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/layout.css" />
    <link rel="stylesheet" href="~/css/homepage.css" />
    <link rel="stylesheet" href="~/css/category.css" />

</head>

<body>

    <nav class="navbar navbar-expand-lg sticky-top" id="mainNav">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <span class="brand-icon">🍳</span>
                CookPad
            </a>

            <!-- Search (desktop) -->
            <div class="search-wrap d-none d-lg-block">
                <form method="get"
                      asp-controller="Recipe"
                      asp-action="Search"
                      class="search-form">
                    <i class="bi bi-search"></i>
                    <input type="text"
                           name="query"
                           class="search-input"
                           placeholder="Tìm món ăn, nguyên liệu..." />
                </form>
            </div>

            <!-- Actions -->
            <div class="nav-actions ms-auto">

                <!-- Mobile search toggle -->
                <button class="btn btn-sm d-lg-none p-2 rounded-circle border-0"
                        style="background:var(--bg);"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mobileSearch">
                    <i class="bi bi-search"></i>
                </button>

                @if (!string.IsNullOrEmpty(token))
                {
                    <!-- User dropdown -->
                    <div class="dropdown">
                        <button class="avatar-btn" data-bs-toggle="dropdown" aria-expanded="false">
                            <span class="avatar-ring">
                                <img src="~/images/avatar-default.png" alt="avatar" />
                            </span>
                            <i class="bi bi-chevron-down avatar-chevron d-none d-lg-inline"></i>
                        </button>

                        <ul class="dropdown-menu dropdown-menu-end">
                            <!-- User info header -->
                            <li class="dropdown-user-info">
                                <img src="~/images/avatar-default.png"
                                     class="dropdown-avatar" alt="avatar" />
                                <div class="dropdown-username">@userName</div>
                                <div class="dropdown-welcome">Welcome back 👋</div>
                            </li>

                            <li><hr class="dropdown-divider" /></li>

                            <li>
                                <a class="dropdown-item" asp-controller="Recipe" asp-action="Index">
                                    <i class="bi bi-journal-bookmark-fill"></i> My Recipes
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-controller="Bookmark" asp-action="Index">
                                    <i class="bi bi-bookmark-heart-fill"></i> Bookmarks
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-controller="Following" asp-action="Index">
                                    <i class="bi bi-people-fill"></i> Following
                                </a>
                            </li>

                            <li><hr class="dropdown-divider" /></li>

                            <li>
                                <a class="dropdown-item text-danger" asp-controller="Auth" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right"></i> Đăng xuất
                                </a>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a class="btn-login" href="/Auth/Login">Đăng nhập</a>
                    <a class="btn-signup" href="/Auth/Register">Đăng ký</a>
                }
            </div>
        </div>

        <!-- Mobile search collapse -->
        <div class="collapse" id="mobileSearch">
            <div class="container pb-2">
                <form method="get"
                      asp-controller="Recipe"
                      asp-action="Search"
                      class="search-form">
                    <i class="bi bi-search"></i>
                    <input type="text"
                           name="query"
                           class="search-input"
                           placeholder="Tìm món ăn, nguyên liệu..." />
                </form>
            </div>
        </div>
    </nav>

   
    <main>
        @RenderBody()
    </main>

   
    <footer>
        <div class="container py-4 py-lg-5">
            <div class="row g-4">

                <!-- Brand column -->
                <div class="col-12 col-lg-4">
                    <div class="footer-brand mb-2">
                        <span>🍳</span> CookPad
                    </div>
                    <p class="footer-desc">
                        Nền tảng chia sẻ công thức nấu ăn dành cho mọi người.
                        Khám phá, nấu và kết nối.
                    </p>
                    <!-- Social -->
                    <div class="d-flex gap-2 mt-3">
                        <a href="#" class="social-btn"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="social-btn"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="social-btn"><i class="bi bi-youtube"></i></a>
                        <a href="#" class="social-btn"><i class="bi bi-tiktok"></i></a>
                    </div>
                </div>

                <!-- Links -->
                <div class="col-6 col-lg-2 offset-lg-1">
                    <div class="footer-heading">Khám phá</div>
                    <ul class="footer-links">
                        <li><a href="#">Món mới nhất</a></li>
                        <li><a href="#">Phổ biến nhất</a></li>
                        <li><a href="#">Theo danh mục</a></li>
                        <li><a href="#">Video nấu ăn</a></li>
                    </ul>
                </div>

                <div class="col-6 col-lg-2">
                    <div class="footer-heading">Tài khoản</div>
                    <ul class="footer-links">
                        <li><a asp-controller="Auth" asp-action="Login">Đăng nhập</a></li>
                        <li><a asp-controller="Auth" asp-action="Register">Đăng ký</a></li>
                        <li><a href="#">Hồ sơ cá nhân</a></li>
                        <li><a href="#">Cài đặt</a></li>
                    </ul>
                </div>

                <div class="col-6 col-lg-2">
                    <div class="footer-heading">Hỗ trợ</div>
                    <ul class="footer-links">
                        <li><a href="#">Về chúng tôi</a></li>
                        <li><a href="#">Liên hệ</a></li>
                        <li><a href="#">Chính sách BM</a></li>
                        <li><a href="#">Điều khoản DV</a></li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="footer-bottom">
            <div class="container d-flex flex-wrap justify-content-between align-items-center gap-2">
                <span>© 2026 CookPad. All rights reserved.</span>
                <span>Made with ❤️ in Vietnam</span>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Navbar shadow on scroll
        const nav = document.getElementById('mainNav');
        window.addEventListener('scroll', () => {
            nav.classList.toggle('scrolled', window.scrollY > 10);
        });
    </script>

    @RenderSection("Scripts", false)
    @RenderSection("Styles", false)

</body>
</html>
