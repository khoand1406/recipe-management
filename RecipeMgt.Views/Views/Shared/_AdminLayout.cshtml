<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Admin Panel</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="~/css/usermgt.css" rel="stylesheet" />

    <style>
        *, *::before, *::after { box-sizing: border-box; }

        :root {
            --sidebar-w:         260px;
            --sidebar-w-mini:    72px;
            --topbar-h:          64px;
            --brand-from:        #4f46e5;
            --brand-to:          #7c3aed;
            --sidebar-bg:        #0f172a;
            --sidebar-text:      #94a3b8;
            --sidebar-hover-bg:  rgba(255,255,255,.06);
            --sidebar-active-bg: rgba(79,70,229,.18);
            --sidebar-active:    #a5b4fc;
            --topbar-bg:         #ffffff;
            --page-bg:           #f1f5f9;
            --transition:        .22s ease;
        }

        html, body {
            height: 100%;
            margin: 0;
            font-family: 'Inter', 'Segoe UI', sans-serif;
            font-size: 14px;
            background: var(--page-bg);
            color: #1e293b;
        }

        /* ── Layout shell ── */
        .admin-shell {
            display: flex;
            min-height: 100vh;
        }

        /* ══════════════════════════════════════
           SIDEBAR
        ══════════════════════════════════════ */
        .sidebar {
            width: var(--sidebar-w);
            background: var(--sidebar-bg);
            display: flex;
            flex-direction: column;
            position: fixed;
            inset: 0 auto 0 0;
            z-index: 1040;
            transition: width var(--transition), transform var(--transition);
            overflow: hidden;
        }
        .sidebar.collapsed { width: var(--sidebar-w-mini); }

        /* Brand */
        .sidebar-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 0 18px;
            height: var(--topbar-h);
            text-decoration: none;
            flex-shrink: 0;
            border-bottom: 1px solid rgba(255,255,255,.06);
            overflow: hidden;
        }
        .brand-icon {
            width: 36px; height: 36px;
            border-radius: 10px;
            background: linear-gradient(135deg, var(--brand-from), var(--brand-to));
            display: flex; align-items: center; justify-content: center;
            color: #fff; font-size: 1.1rem; flex-shrink: 0;
        }
        .brand-name {
            font-weight: 700; font-size: .95rem; color: #fff;
            white-space: nowrap;
            transition: opacity var(--transition), max-width var(--transition);
            max-width: 200px; overflow: hidden;
        }
        .sidebar.collapsed .brand-name { opacity: 0; max-width: 0; }

        /* Nav scroll */
        .sidebar-nav {
            flex: 1; overflow-y: auto; overflow-x: hidden;
            padding: 12px 0;
            scrollbar-width: thin;
            scrollbar-color: rgba(255,255,255,.1) transparent;
        }
        .sidebar-nav::-webkit-scrollbar { width: 4px; }
        .sidebar-nav::-webkit-scrollbar-thumb { background: rgba(255,255,255,.1); border-radius: 4px; }

        /* Section label */
        .nav-section-label {
            font-size: .65rem; font-weight: 700;
            letter-spacing: .1em; text-transform: uppercase;
            color: rgba(148,163,184,.5);
            padding: 14px 20px 6px;
            white-space: nowrap;
            transition: opacity var(--transition);
        }
        .sidebar.collapsed .nav-section-label { opacity: 0; }

        /* Nav item */
        .nav-item-link {
            display: flex; align-items: center; gap: 12px;
            padding: 10px 18px;
            margin: 2px 8px;
            border-radius: 10px;
            color: var(--sidebar-text);
            text-decoration: none;
            transition: background var(--transition), color var(--transition);
            white-space: nowrap; overflow: hidden;
            position: relative;
        }
        .nav-item-link:hover { background: var(--sidebar-hover-bg); color: #e2e8f0; }
        .nav-item-link.active {
            background: var(--sidebar-active-bg);
            color: var(--sidebar-active);
            font-weight: 600;
        }
        .nav-item-link.active::before {
            content: '';
            position: absolute; left: 0; top: 20%; bottom: 20%;
            width: 3px; background: var(--brand-from);
            border-radius: 0 3px 3px 0;
        }
        .nav-icon { font-size: 1.1rem; flex-shrink: 0; width: 22px; text-align: center; }
        .nav-label {
            font-size: .875rem;
            transition: opacity var(--transition), max-width var(--transition);
            max-width: 160px; overflow: hidden;
        }
        .sidebar.collapsed .nav-label { opacity: 0; max-width: 0; }

        /* Badge */
        .nav-badge {
            margin-left: auto;
            background: var(--brand-from); color: #fff;
            font-size: .65rem; font-weight: 700;
            padding: 2px 7px; border-radius: 999px;
            transition: opacity var(--transition);
        }
        .sidebar.collapsed .nav-badge { opacity: 0; }

        /* Divider */
        .sidebar-divider { height: 1px; background: rgba(255,255,255,.06); margin: 8px 16px; }

        /* Collapsed: center icons + tooltip */
        .sidebar.collapsed .nav-item-link {
            justify-content: center;
            padding-left: 0; padding-right: 0;
        }
        .sidebar.collapsed .nav-item-link::after {
            content: attr(data-title);
            position: absolute;
            left: calc(var(--sidebar-w-mini) + 10px);
            background: #1e293b; color: #e2e8f0;
            padding: 5px 10px; border-radius: 7px;
            font-size: .78rem; white-space: nowrap;
            pointer-events: none; opacity: 0;
            transition: opacity .15s;
            box-shadow: 0 4px 12px rgba(0,0,0,.3);
            z-index: 9999;
        }
        .sidebar.collapsed .nav-item-link:hover::after { opacity: 1; }

        /* Sidebar footer */
        .sidebar-footer {
            border-top: 1px solid rgba(255,255,255,.06);
            padding: 14px 18px;
            display: flex; align-items: center; gap: 10px;
            overflow: hidden; flex-shrink: 0;
        }
        .user-avatar {
            width: 36px; height: 36px; border-radius: 50%;
            background: linear-gradient(135deg, #06b6d4, #3b82f6);
            display: flex; align-items: center; justify-content: center;
            color: #fff; font-weight: 700; font-size: .85rem; flex-shrink: 0;
        }
        .user-info { overflow: hidden; transition: opacity var(--transition), max-width var(--transition); max-width: 160px; }
        .user-name  { font-size: .82rem; font-weight: 600; color: #e2e8f0; white-space: nowrap; }
        .user-role  { font-size: .72rem; color: var(--sidebar-text); white-space: nowrap; }
        .sidebar.collapsed .user-info { opacity: 0; max-width: 0; }

        /* ══════════════════════════════════════
           MAIN AREA — margin controlled by JS class on body
        ══════════════════════════════════════ */
        .main-area {
            margin-left: var(--sidebar-w);
            flex: 1; display: flex; flex-direction: column;
            min-height: 100vh;
            transition: margin-left var(--transition);
        }
        /* ✅ Fix: dùng body class thay vì CSS sibling selector */
        body.sidebar-collapsed .main-area { margin-left: var(--sidebar-w-mini); }

        /* ── Topbar ── */
        .topbar {
            height: var(--topbar-h);
            background: var(--topbar-bg);
            border-bottom: 1px solid #e2e8f0;
            display: flex; align-items: center;
            padding: 0 24px; gap: 12px;
            position: sticky; top: 0; z-index: 1030;
            box-shadow: 0 1px 4px rgba(0,0,0,.05);
        }
        .btn-toggle {
            width: 36px; height: 36px; border-radius: 9px;
            border: none; background: #f1f5f9; color: #64748b;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem; cursor: pointer; flex-shrink: 0;
            transition: background var(--transition), color var(--transition);
        }
        .btn-toggle:hover { background: #e2e8f0; color: #1e293b; }

        /* Breadcrumb */
        .topbar-breadcrumb { flex: 1; }
        .topbar-breadcrumb .breadcrumb { margin: 0; font-size: .8rem; }
        .topbar-breadcrumb .breadcrumb-item a { color: #64748b; text-decoration: none; }
        .topbar-breadcrumb .breadcrumb-item a:hover { color: var(--brand-from); }
        .topbar-breadcrumb .breadcrumb-item.active { color: #1e293b; font-weight: 600; }

        /* Topbar actions */
        .topbar-actions { display: flex; align-items: center; gap: 8px; }
        .topbar-icon-btn {
            width: 36px; height: 36px; border-radius: 9px;
            border: none; background: #f1f5f9; color: #64748b;
            display: flex; align-items: center; justify-content: center;
            font-size: 1rem; cursor: pointer; position: relative;
            transition: background var(--transition), color var(--transition);
            text-decoration: none;
        }
        .topbar-icon-btn:hover { background: #e2e8f0; color: #1e293b; }
        .notif-dot {
            position: absolute; top: 6px; right: 6px;
            width: 8px; height: 8px;
            background: #ef4444;
            border: 2px solid var(--topbar-bg);
            border-radius: 50%;
        }
        .topbar-divider { width: 1px; height: 24px; background: #e2e8f0; margin: 0 4px; }
        .topbar-user {
            display: flex; align-items: center; gap: 8px;
            padding: 4px 10px 4px 4px; border-radius: 10px;
            cursor: pointer; text-decoration: none;
            transition: background var(--transition);
        }
        .topbar-user:hover { background: #f1f5f9; }
        .topbar-avatar {
            width: 32px; height: 32px; border-radius: 50%;
            background: linear-gradient(135deg, #06b6d4, #3b82f6);
            display: flex; align-items: center; justify-content: center;
            color: #fff; font-weight: 700; font-size: .78rem;
        }
        .topbar-user-name { font-size: .82rem; font-weight: 600; color: #1e293b; white-space: nowrap; }

        /* Page content */
        .page-content { flex: 1; padding: 28px 28px 40px; }

        /* Footer */
        .admin-footer {
            background: var(--topbar-bg); border-top: 1px solid #e2e8f0;
            padding: 14px 28px; font-size: .75rem; color: #94a3b8;
            display: flex; justify-content: space-between; align-items: center;
        }

        /* ══════════════════════════════════════
           MOBILE
        ══════════════════════════════════════ */
        .sidebar-overlay {
            display: none; position: fixed; inset: 0;
            background: rgba(0,0,0,.45); z-index: 1039;
            backdrop-filter: blur(2px);
        }
        .sidebar-overlay.show { display: block; }

        @@media (max-width: 991px) {
            .sidebar { transform: translateX(-100%); width: var(--sidebar-w) !important; }
            .sidebar.mobile-open { transform: translateX(0); }
            .main-area { margin-left: 0 !important; }
            .page-content { padding: 20px 16px 32px; }
        }
        @@media (max-width: 575px) {
            .topbar-breadcrumb { display: none; }
            .topbar-user-name  { display: none; }
        }

        /* Scroll to top */
        #scrollTop {
            position: fixed; bottom: 28px; right: 28px;
            width: 40px; height: 40px; border-radius: 50%;
            background: var(--brand-from); color: #fff;
            border: none; box-shadow: 0 4px 14px rgba(79,70,229,.4);
            display: flex; align-items: center; justify-content: center;
            font-size: 1rem; cursor: pointer;
            opacity: 0; pointer-events: none;
            transition: opacity .3s, transform .3s; z-index: 999;
        }
        #scrollTop.visible { opacity: 1; pointer-events: auto; }
        #scrollTop:hover { transform: translateY(-3px); }
    </style>

    @RenderSection("Styles", required: false)
</head>
<body>

<div class="admin-shell">

    @* ══════════ SIDEBAR ══════════ *@
    <aside class="sidebar" id="sidebar">

        @* Brand *@
        <a class="sidebar-brand" href="/admin/dashboard">
            <div class="brand-icon"><i class="bi bi-egg-fried"></i></div>
            <span class="brand-name">FoodAdmin</span>
        </a>

        @* Nav *@
        <nav class="sidebar-nav">

            <div class="nav-section-label">Main</div>

            <a class="nav-item-link @(ViewData["ActiveNav"]?.ToString() == "dashboard" ? "active" : "")"
               href="/admin/dashboard" data-title="Dashboard">
                <i class="bi bi-speedometer2 nav-icon"></i>
                <span class="nav-label">Dashboard</span>
            </a>

            <div class="sidebar-divider"></div>
            <div class="nav-section-label">Quản lý</div>

            <a class="nav-item-link @(ViewData["ActiveNav"]?.ToString() == "dishes" ? "active" : "")"
               href="/admin/dishes" data-title="Món ăn">
                <i class="bi bi-cup-hot nav-icon"></i>
                <span class="nav-label">Món ăn</span>
            </a>

            <a class="nav-item-link @(ViewData["ActiveNav"]?.ToString() == "recipes" ? "active" : "")"
               href="/admin/recipes" data-title="Công thức">
                <i class="bi bi-journal-richtext nav-icon"></i>
                <span class="nav-label">Công thức</span>
            </a>

            <a class="nav-item-link @(ViewData["ActiveNav"]?.ToString() == "categories" ? "active" : "")"
               href="/admin/categories" data-title="Danh mục">
                <i class="bi bi-grid nav-icon"></i>
                <span class="nav-label">Danh mục</span>
            </a>

            <a class="nav-item-link @(ViewData["ActiveNav"]?.ToString() == "reviews" ? "active" : "")"
               href="/admin/reviews" data-title="Đánh giá">
                <i class="bi bi-star nav-icon"></i>
                <span class="nav-label">Đánh giá</span>
                <span class="nav-badge">New</span>
            </a>

            <a class="nav-item-link @(ViewData["ActiveNav"]?.ToString() == "users" ? "active" : "")"
               href="/admin/users" data-title="Người dùng">
                <i class="bi bi-people nav-icon"></i>
                <span class="nav-label">Người dùng</span>
            </a>

            <div class="sidebar-divider"></div>
            <div class="nav-section-label">Hệ thống</div>

            <a class="nav-item-link @(ViewData["ActiveNav"]?.ToString() == "settings" ? "active" : "")"
               href="/admin/settings" data-title="Cài đặt">
                <i class="bi bi-gear nav-icon"></i>
                <span class="nav-label">Cài đặt</span>
            </a>

            <a class="nav-item-link" href="/" target="_blank" data-title="Xem website">
                <i class="bi bi-box-arrow-up-right nav-icon"></i>
                <span class="nav-label">Xem website</span>
            </a>

        </nav>

        @* Footer user *@
        <div class="sidebar-footer">
            <div class="user-avatar">A</div>
            <div class="user-info">
                <div class="user-name">Admin</div>
                <div class="user-role">Super Admin</div>
            </div>
        </div>

    </aside>

    @* Mobile overlay *@
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    @* ══════════ MAIN AREA ══════════ *@
    <div class="main-area">

        @* Topbar *@
        <header class="topbar">

            <button class="btn-toggle" id="sidebarToggle" title="Toggle sidebar">
                <i class="bi bi-list"></i>
            </button>

            <nav class="topbar-breadcrumb" aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a href="/admin/dashboard"><i class="bi bi-house me-1"></i>Admin</a>
                    </li>
                    @if (ViewData["BreadcrumbParent"] != null)
                    {
                        <li class="breadcrumb-item">
                            <a href="@ViewData["BreadcrumbParentUrl"]">@ViewData["BreadcrumbParent"]</a>
                        </li>
                    }
                    <li class="breadcrumb-item active">@ViewData["Title"]</li>
                </ol>
            </nav>

            <div class="topbar-actions">

                <button class="topbar-icon-btn" title="Tìm kiếm">
                    <i class="bi bi-search"></i>
                </button>

                <button class="topbar-icon-btn" title="Thông báo">
                    <i class="bi bi-bell"></i>
                    <span class="notif-dot"></span>
                </button>

                <div class="topbar-divider"></div>

                <div class="dropdown">
                    <a class="topbar-user" href="#"
                       data-bs-toggle="dropdown" aria-expanded="false">
                        <div class="topbar-avatar">A</div>
                        <span class="topbar-user-name">Admin</span>
                        <i class="bi bi-chevron-down ms-1" style="font-size:.7rem;color:#94a3b8;"></i>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-1"
                        style="border-radius:12px;min-width:180px;">
                        <li>
                            <a class="dropdown-item py-2" href="/admin/profile">
                                <i class="bi bi-person me-2 text-muted"></i>Hồ sơ
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item py-2" href="/admin/settings">
                                <i class="bi bi-gear me-2 text-muted"></i>Cài đặt
                            </a>
                        </li>
                        <li><hr class="dropdown-divider my-1"></li>
                        <li>
                            <a class="dropdown-item py-2 text-danger" href="/auth/logout">
                                <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                            </a>
                        </li>
                    </ul>
                </div>

            </div>
        </header>

        @* Page body *@
        <main class="page-content">
            @RenderBody()
        </main>

        @* Footer *@
        <footer class="admin-footer">
            <span>© @DateTime.Now.Year FoodAdmin — All rights reserved</span>
            <span>v1.0.0</span>
        </footer>

    </div>@* /main-area *@

</div>@* /admin-shell *@

<button id="scrollTop" title="Lên đầu trang">
    <i class="bi bi-arrow-up"></i>
</button>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
(function () {
    const sidebar   = document.getElementById('sidebar');
    const overlay   = document.getElementById('sidebarOverlay');
    const toggle    = document.getElementById('sidebarToggle');
    const scrollBtn = document.getElementById('scrollTop');
    const body      = document.body;

    const MOBILE_BP = 992;
    const LS_KEY    = 'admin_sidebar_collapsed';

    /* ── Restore collapsed state on desktop ── */
    if (window.innerWidth >= MOBILE_BP && localStorage.getItem(LS_KEY) === '1') {
        sidebar.classList.add('collapsed');
        body.classList.add('sidebar-collapsed');      // ✅ sync body class
    }

    /* ── Toggle ── */
    toggle.addEventListener('click', () => {
        if (window.innerWidth >= MOBILE_BP) {
            const collapsed = sidebar.classList.toggle('collapsed');
            body.classList.toggle('sidebar-collapsed', collapsed);   // ✅
            localStorage.setItem(LS_KEY, collapsed ? '1' : '0');
        } else {
            const open = sidebar.classList.toggle('mobile-open');
            overlay.classList.toggle('show', open);
        }
    });

    /* ── Overlay click (mobile close) ── */
    overlay.addEventListener('click', () => {
        sidebar.classList.remove('mobile-open');
        overlay.classList.remove('show');
    });

    /* ── Close on nav click (mobile) ── */
    document.querySelectorAll('.nav-item-link').forEach(link => {
        link.addEventListener('click', () => {
            if (window.innerWidth < MOBILE_BP) {
                sidebar.classList.remove('mobile-open');
                overlay.classList.remove('show');
            }
        });
    });

    /* ── Resize guard ── */
    window.addEventListener('resize', () => {
        if (window.innerWidth >= MOBILE_BP) {
            sidebar.classList.remove('mobile-open');
            overlay.classList.remove('show');
        }
    });

    /* ── Scroll to top ── */
    window.addEventListener('scroll', () => {
        scrollBtn.classList.toggle('visible', window.scrollY > 300);
    });
    scrollBtn.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
    });
})();
</script>

@RenderSection("Scripts", required: false)

</body>
</html>
